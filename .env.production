# Production Environment Variables
# Copy this to .env and fill in your values

# Backend Variables
MONGO_URL=mongodb://mongodb:27017
DB_NAME=real_estate_platform
CORS_ORIGINS=*
EMERGENT_LLM_KEY=your-emergent-key-here

# Frontend Variables (set before building)
REACT_APP_BACKEND_URL=http://your-vps-ip:8001

# Optional: Set these if you want to expose MongoDB externally
# MONGO_INITDB_ROOT_USERNAME=admin
# MONGO_INITDB_ROOT_PASSWORD=your-secure-password

# Google Maps API Key (if you have your own)
# GOOGLE_MAPS_API_KEY=your-google-maps-key